{
  "info": {
    "name": "PaperPulse — API Collection (code thực tế)",
    "_postman_id": "paperpulse-c2-app-069-v2",
    "description": "Endpoints theo flow mới nhất (human-in-the-loop, 4 requests per test case).\nBase URL: http://localhost:8000\n\n⭐ FLOW CHÍNH:\nR1: POST /api/research/stream  {\"query\": \"...\", \"thread_id\": null}\n    → Interrupt 1: plan review → lấy thread_id từ response\nR2: POST /api/research/resume  {\"thread_id\": \"...\", \"resume_value\": true}\n    → Interrupt 2: outline approval\nR3: POST /api/research/resume  (same body)\n    → Interrupt 3: routing summary (informational)\nR4: POST /api/research/resume  (same body)\n    → {\"type\": \"done\"} = output thật sự\n\n⚠️ Lưu thread_id từ R1 vào Postman variable để dùng R2-R4.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "thread_id",
      "value": "",
      "type": "string",
      "description": "Copy từ response R1 (POST /research/stream), dùng cho R2-R4"
    }
  ],
