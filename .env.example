# LLM Provider
PROVIDER=openai                    # openai | anthropic | google | custom
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=                      # Base URL if using custom endpoint
LLM_TEMPERATURE=0.7

# Embedding
EMBEDDING_MODEL=nvidia/nv-embed-v1 # NVIDIA NIM requires the "nvidia/" catalog prefix
EMBEDDING_BASE_URL=                # Base URL if using custom embedding endpoint

# Semantic Scholar
SEMANTIC_SCHOLAR_API_KEY=          # Increases rate limits

# OpenAlex (polite pool — no key needed, email improves rate limits)
OPENALEX_EMAIL=                    # e.g. your@email.com

# ChromaDB — "embedded" (default, in-process) or "http" (talks to a chroma
# server, e.g. `docker compose up -d chromadb` — see docker-compose.yml)
CHROMA_MODE=embedded
CHROMA_PERSIST_PATH=./data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8002

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-or-service-role-key>
SUPABASE_SERVICE_KEY=

# Per-role LLM temperatures
INTENT_TEMPERATURE=0
OUTLINE_TEMPERATURE=0.7
CLAIM_TEMPERATURE=0
VERIFIER_TEMPERATURE=0
EXPORT_TEMPERATURE=0.7

# LaTeX output directory
LATEX_OUTPUT_DIR=./data/output

# Knowledge Graph guardrails (Step ⑨bis)
KG_MAX_NODES_RENDERED=500
KG_MAX_EDGES_RENDERED=3000
KG_CONTRADICTS_CLUSTER_MIN_SIZE=2

# PDF Agent (pdf-agent_PLAN_2.0.md)
PDF_AGENT_CHECKPOINT_DB=./data/pdf_agent_checkpoints.db
PDF_AGENT_OUTPUT_DIR=./data/pdf_agent_output

# MinerU — self-host PDF OCR/layout (falls back to PyMuPDF if unavailable)
MINERU_MODE=cli
MINERU_BIN=mineru
MINERU_TMP_DIR=./data/mineru_tmp
MINERU_DEVICE_MODE=cpu
MINERU_TIMEOUT_S=120
MINERU_API_URL=http://localhost:8001
CRITIC_TEMPERATURE=0
EXPLAIN_TEMPERATURE=0.3
REWRITE_TEMPERATURE=0.5
PDF_JUDGE_TEMPERATURE=0
PDF_AGENT_MAX_FILE_SIZE_MB=20
PDF_AGENT_MAX_PAGES=60
PDF_AGENT_MAX_CITATIONS_VERIFY=150
PDF_AGENT_MAX_SECTIONS_CRITIC=20
PDF_AGENT_CITATION_LOOKUP_TIMEOUT_S=10
PDF_AGENT_LINK_CHECK_TIMEOUT_S=5
PDF_AGENT_ANCHOR_CONTEXT_CHARS=32
PDF_AGENT_MATCH_THRESHOLD_HIGH=0.85
PDF_AGENT_MATCH_THRESHOLD_LOW=0.55

# Payment — PayOS merchant credentials, from the PayOS
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
FRONTEND_BASE_URL=http://localhost:5173

# App
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
APP_ENV=development
LOG_LEVEL=INFO

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=
AI_LOG_API_KEY=
AI_LOG_DIR=.ai-log
